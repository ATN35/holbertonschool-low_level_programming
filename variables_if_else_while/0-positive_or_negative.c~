# inclure  < stdlib.h >
# inclure  < heure.h >
# inclure  < stdio.h >

/* *
 *principal - Point d'entrée
 *Retour : toujours 0 (succès)
 */

int  principal ( vide )
{
	int n ;

	srand ( temps ( 0 ));
	n = rand () - RAND_MAX / 2 ;

	si (n > 0 )
	{
		printf ( " %i est positif \n " , n);
	}
	sinon  si (n == 0 )
	{
		printf ( " %i vaut zéro \n " , n);
	}
	sinon  si (n < 0 )
	{
		printf ( " %i est négatif \n " , n);
	}

	retour ( 0 );
}
