/* *
 * times_table - Imprime la table de multiplication par 9
 *
 * Retour : pas de retour
 */
void  times_table ( void )
{
	entier a, b, op ;

	pour (a = 0 ; a <= 9 ; a++)
	{
		_putchar ( 48 );
		pour (b = 1 ; b <= 9 ; b++)
		{
			op = un * b;
			_putchar ( 44 );
			_putchar ( 32 );
			si (op <= 9 )
			{
				_putchar ( 32 );
				_putchar (op + 48 );
			}
			autre
			{
				_putchar ((op / 10 ) + 48 );
				_putchar ((op % 10 ) + 48 );
			}
		}
		_putchar ( ' \n ' );
	}
}
